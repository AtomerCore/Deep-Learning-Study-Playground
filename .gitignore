# =========================================
# 1. PyCharm 专属配置 (核心)
# =========================================
.idea/                # PyCharm 的工程配置文件夹，绝对不要传
*.iml                 # IntelliJ IDEA 模块文件
workspace.xml         # 经常变动，容易引发冲突

# =========================================
# 2. Python 编译与缓存
# =========================================
__pycache__/          # Python 编译后的字节码缓存
*.py[cod]             # .pyc, .pyo, .pyd 等编译文件
*$py.class            # Jython 编译文件
.Python               # Python 可执行文件
build/                # 构建目录
dist/                 # 分发目录
*.egg-info/           # Python 包的元数据
*.egg                 # 打包文件
*.whl                 # Wheel 包

# =========================================
# 3. 虚拟环境 (非常重要，体积通常很大)
# =========================================
venv/                 # 常见的虚拟环境目录名
env/                  # 另一种常见的虚拟环境目录名
ENV/
.venv/
pip-selfcheck.json    # Pip 缓存

# =========================================
# 4. Jupyter Notebook (如果你用的话)
# =========================================
.ipynb_checkpoints/   # Notebook 的自动保存检查点

# =========================================
# 5. 操作系统临时文件
# =========================================
.DS_Store             # Mac 系统产生的文件夹属性文件
Thumbs.db             # Windows 系统产生的缩略图
desktop.ini           # Windows 文件夹自定义图标文件

# =========================================
# 6. 日志与临时文件
# =========================================
*.log                 # 日志文件
*.swp                 # Vim 产生的临时交换文件
*.swo                 # Vim 产生的临时交换文件